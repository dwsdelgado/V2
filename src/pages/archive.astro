---
import projects from '@/data/projects.json'
import me from '@/data/me.json'
import '@fontsource-variable/inter'
import '@/styles/global.css'

const title = `Todos los Proyectos — ${me.fullName}`
---

<!doctype html>
<html lang='es' data-theme='dark'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700&display=swap" rel="stylesheet" />
  <script is:inline>
    localStorage.theme = 'dark'
    document.documentElement.dataset.theme = 'dark'
  </script>
</head>
<body style="background: #0f172a; color: #94a3b8; min-height: 100vh;">
  <div class="max-w-5xl mx-auto px-6 md:px-12 py-8 md:py-12">

    <!-- Back link -->
    <a
      href="/"
      class="back-link inline-flex items-center gap-2 text-sm font-medium mb-8 transition-colors duration-200"
      style="color: #64748b"
    >
      ← {me.fullName}
    </a>

    <!-- Title -->
    <h1 class="text-5xl font-bold mb-16" style="font-family: var(--font-display); color: #e2e8f0">
      Todos los Proyectos
    </h1>

    <!-- Table -->
    <table class="w-full text-sm border-collapse" style="table-layout: fixed">
      <colgroup>
        <col style="width: 60px" />
        <col style="width: 35%" />
        <col class="hidden sm:table-column" style="width: 15%" />
        <col class="hidden md:table-column" style="width: 35%" />
        <col class="hidden lg:table-column" style="width: 10%" />
      </colgroup>
      <thead>
        <tr style="border-bottom: 1px solid #334155">
          <th class="text-left pb-4 pr-4 text-xs font-bold tracking-widest uppercase" style="color: #64748b">Año</th>
          <th class="text-left pb-4 pr-4 text-xs font-bold tracking-widest uppercase" style="color: #64748b">Proyecto</th>
          <th class="text-left pb-4 pr-4 text-xs font-bold tracking-widest uppercase hidden sm:table-cell" style="color: #64748b">Empresa</th>
          <th class="text-left pb-4 pr-4 text-xs font-bold tracking-widest uppercase hidden md:table-cell" style="color: #64748b">Construido con</th>
          <th class="text-left pb-4 text-xs font-bold tracking-widest uppercase hidden lg:table-cell" style="color: #64748b">Link</th>
        </tr>
      </thead>
      <tbody>
        {projects.map((project) => {
          const year = project.date?.split('-')[0] || '—'
          return (
            <tr class="proj-row border-b transition-colors duration-200" style="border-color: #334155">
              <td class="py-4 pr-4 align-top font-mono text-xs" style="color: #64748b">{year}</td>
              <td class="py-4 pr-4 align-top font-semibold text-sm" style="color: #e2e8f0">{project.title}</td>
              <td class="py-4 pr-4 align-top text-sm hidden sm:table-cell" style="color: #64748b">{(project as any).company || '—'}</td>
              <td class="py-4 pr-4 align-top hidden md:table-cell">
                <div class="flex flex-wrap gap-1.5">
                  {project.skills?.map((skill: string) => (
                    <span class="px-2 py-0.5 rounded-full text-xs" style="background: #1e293b; color: #5eead4; border: 1px solid #334155">
                      {skill}
                    </span>
                  ))}
                </div>
              </td>
              <td class="py-4 align-top hidden lg:table-cell">
                {project.url ? (
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="proj-link text-xs transition-colors duration-200" style="color: #64748b">
                    Ver ↗
                  </a>
                ) : (
                  <span style="color: #64748b; opacity: 0.3">—</span>
                )}
              </td>
            </tr>
          )
        })}
      </tbody>
    </table>
  </div>
</body>
</html>

<style>
  .back-link:hover {
    color: #5eead4 !important;
  }

  .proj-row:hover td {
    color: #5eead4 !important;
  }

  .proj-row:hover {
    background: #1e293b;
  }

  .proj-link:hover {
    color: #5eead4 !important;
  }
</style>
