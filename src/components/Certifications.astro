---
import certifications from '@/data/certifications.json'
---

<section id="certifications" class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24">

  <!-- Mobile sticky header -->
  <div class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0" style="background-color: rgba(15,23,42,0.85)">
    <h2 class="text-sm font-bold uppercase tracking-widest lg:sr-only" style="color: #e2e8f0">Certifications</h2>
  </div>

  <ol class="cert-list">
    {certifications.map((cert) => (
      <li class="mb-12">
        <div class="cert-card group relative grid pb-1 transition-all sm:grid-cols-8 sm:gap-8 md:gap-4">

          <!-- Hover background -->
          <div class="cert-hover absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block"></div>

          <!-- Date column -->
          <header class="z-10 mb-2 mt-1 text-xs font-semibold uppercase tracking-wide sm:col-span-2" style="color: #64748b">
            {cert.date}
          </header>

          <!-- Content column -->
          <div class="z-10 sm:col-span-6">
            <h3 class="font-medium leading-snug" style="color: #e2e8f0; font-size: 1rem">
              {cert.credentialUrl ? (
                <a
                  href={cert.credentialUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cert-link inline-flex items-baseline font-medium leading-tight"
                  style="color: #e2e8f0; font-size: 1rem"
                >
                  <span class="absolute -inset-x-4 -inset-y-2.5 hidden rounded md:-inset-x-6 md:-inset-y-4 lg:block"></span>
                  <span>
                    {cert.name}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block h-4 w-4 shrink-0 ml-1 translate-y-px transition-transform group-hover:-translate-y-1 group-hover:translate-x-1"><path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/></svg>
                  </span>
                </a>
              ) : (
                <span>{cert.name}</span>
              )}
            </h3>
            <p class="mt-1 text-sm" style="color: #5eead4">{cert.issuer}</p>
          </div>

        </div>
      </li>
    ))}
  </ol>

</section>

<style>
  .cert-list:hover .cert-card {
    opacity: 0.5;
  }
  .cert-list:hover .cert-card:hover {
    opacity: 1 !important;
  }
  .cert-card:hover .cert-hover {
    background-color: rgba(30, 41, 59, 0.5);
    box-shadow: inset 0 1px 0 0 rgba(148, 163, 184, 0.1);
  }
  .cert-link:hover {
    color: #5eead4 !important;
  }
</style>
