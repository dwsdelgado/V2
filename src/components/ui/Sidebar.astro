---
import me from '@/data/me.json'
import links from '@/data/links.json'
import { Icon } from 'astro-icon/components'

const anchors = [
  { name: 'Acerca de',       id: 'about-me' },
  { name: 'Experiencia',     id: 'experience' },
  { name: 'Proyectos',       id: 'projects' },
  { name: 'Certificaciones', id: 'certifications' },
]
---

<header class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-[48%] lg:flex-col lg:justify-between lg:py-24 pt-14 pb-4">

  <div>
    <!-- Name + role + tagline -->
    <div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight" style="color: #e2e8f0">
        {me.fullName}
      </h1>
      <h2 class="mt-3 text-lg sm:text-xl font-medium tracking-tight" style="color: #e2e8f0">
        {me.subtitle}
      </h2>
      <p class="mt-4 text-base leading-relaxed max-w-xs" style="color: #94a3b8">
        Infraestructura híbrida, automatización y cloud — construyendo plataformas que escalan con el negocio.
      </p>
    </div>

    <!-- Nav -->
    <nav class="nav hidden lg:block" aria-label="In-page jump links">
      <ul class="mt-16 w-max">
        {anchors.map((anchor) => (
          <li>
            <a
              href={`#${anchor.id}`}
              class="nav-link group flex items-center py-3"
              data-section={anchor.id}
            >
              <span class="nav-indicator mr-4 h-px w-8 transition-all motion-reduce:transition-none" style="background-color: #475569"></span>
              <span class="nav-text text-xs font-bold uppercase tracking-widest" style="color: #64748b">
                {anchor.name}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Social icons -->
  <ul class="flex items-center gap-5 mt-8">
    {links.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          title={link.name}
          class="social-icon block transition-colors duration-200"
          style="color: #cbd5e1"
        >
          <Icon name={link.icon} class="size-8" />
        </a>
      </li>
    ))}
  </ul>
</header>

<style>
  .nav-link.active .nav-indicator,
  .nav-link:hover .nav-indicator,
  .nav-link:focus-visible .nav-indicator {
    width: 4rem;
    background-color: #e2e8f0 !important;
  }

  .nav-link.active .nav-text,
  .nav-link:hover .nav-text,
  .nav-link:focus-visible .nav-text {
    color: #e2e8f0 !important;
  }

  .social-icon:hover {
    color: #5eead4 !important;
  }
</style>

<script>
  const sections = document.querySelectorAll('section[id]')
  const navLinks = document.querySelectorAll('.nav-link')

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        navLinks.forEach((link) => {
          link.classList.remove('active')
          if ((link as HTMLElement).dataset.section === entry.target.id) {
            link.classList.add('active')
          }
        })
      }
    })
  }, { rootMargin: '-40% 0px -55% 0px' })

  sections.forEach((section) => observer.observe(section))
</script>
