---
const anchors = [
  { name: 'Acerca de',      id: 'about-me',       icon: 'person' },
  { name: 'Experiencia',    id: 'experience',      icon: 'briefcase' },
  { name: 'Proyectos',      id: 'projects',        icon: 'code' },
  { name: 'Certificaciones',id: 'certifications',  icon: 'badge' },
]
---

<nav id="mobile-nav" class="lg:hidden fixed bottom-0 left-0 right-0 z-50 px-2 pb-2">
  <div class="rounded-2xl px-2 py-2 flex justify-around items-center" style="background: rgba(15,23,42,0.95); backdrop-filter: blur(12px); border: 1px solid rgba(148,163,184,0.12); box-shadow: 0 -4px 24px rgba(0,0,0,0.4)">
    {anchors.map((anchor) => (
      <a
        href={`#${anchor.id}`}
        data-section={anchor.id}
        class="mobile-nav-link flex flex-col items-center gap-1 px-3 py-2 rounded-xl transition-all duration-200"
        style="color: #64748b; min-width: 64px"
      >
        <svg class="mobile-nav-icon w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          {anchor.icon === 'person' && <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />}
          {anchor.icon === 'briefcase' && <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0" />}
          {anchor.icon === 'code' && <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />}
          {anchor.icon === 'badge' && <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-.421 3.918 3.745 3.745 0 01-3.918.421A3.745 3.745 0 0112 21a3.745 3.745 0 01-3.068-1.593 3.745 3.745 0 01-3.918-.421 3.745 3.745 0 01-.421-3.918A3.745 3.745 0 013 12a3.745 3.745 0 011.593-3.068 3.745 3.745 0 01.421-3.918 3.745 3.745 0 013.918-.421A3.742 3.742 0 0112 3a3.742 3.742 0 013.068 1.593 3.742 3.742 0 013.918.421 3.742 3.742 0 01.421 3.918A3.742 3.742 0 0121 12z" />}
        </svg>
        <span class="mobile-nav-text text-xs font-medium">{anchor.name}</span>
      </a>
    ))}
  </div>
</nav>

<style>
  .mobile-nav-link.active,
  .mobile-nav-link:hover {
    color: #5eead4 !important;
    background: rgba(45,212,191,0.08) !important;
  }
</style>

<script>
  const sections = document.querySelectorAll('section[id]')
  const mobileLinks = document.querySelectorAll('.mobile-nav-link')

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        mobileLinks.forEach((link) => {
          link.classList.remove('active')
          if ((link as HTMLElement).dataset.section === entry.target.id) {
            link.classList.add('active')
          }
        })
      }
    })
  }, { rootMargin: '-30% 0px -60% 0px' })

  sections.forEach((section) => observer.observe(section))
</script>
