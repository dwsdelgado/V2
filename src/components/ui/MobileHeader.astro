---
const anchors = [
  { name: 'Acerca de',       id: 'about-me' },
  { name: 'Experiencia',     id: 'experience' },
  { name: 'Proyectos',       id: 'projects' },
  { name: 'Certificaciones', id: 'certifications' },
]
---

<div id="mobile-header" class="lg:hidden fixed top-0 left-0 right-0 z-50 flex items-center justify-end px-6 py-4" style="background: rgba(15,23,42,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(148,163,184,0.1)">
  <button
    id="hamburger-btn"
    aria-label="Abrir menú"
    class="flex flex-col justify-center items-center gap-1.5 p-2 rounded-lg transition-colors"
    style="color: #e2e8f0"
  >
    <span class="hamburger-line block h-0.5 w-6 rounded transition-all duration-300" style="background: currentColor"></span>
    <span class="hamburger-line block h-0.5 w-6 rounded transition-all duration-300" style="background: currentColor"></span>
    <span class="hamburger-line block h-0.5 w-6 rounded transition-all duration-300" style="background: currentColor"></span>
  </button>
</div>

<!-- Dropdown menu -->
<div id="mobile-menu" class="lg:hidden fixed top-[57px] left-0 right-0 z-40 hidden" style="background: rgba(15,23,42,0.97); backdrop-filter: blur(16px); border-bottom: 1px solid rgba(148,163,184,0.1)">
  <nav class="px-6 py-4">
    <ul class="space-y-1">
      {anchors.map((anchor) => (
        <li>
          <a
            href={`#${anchor.id}`}
            class="mobile-menu-link block px-4 py-3 rounded-xl text-sm font-semibold uppercase tracking-widest transition-all duration-200"
            style="color: #64748b"
          >
            {anchor.name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .mobile-menu-link:hover,
  .mobile-menu-link.active {
    color: #5eead4 !important;
    background: rgba(45,212,191,0.08) !important;
  }
  #hamburger-btn.open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #hamburger-btn.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #hamburger-btn.open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const btn = document.getElementById('hamburger-btn')
  const menu = document.getElementById('mobile-menu')
  const links = document.querySelectorAll('.mobile-menu-link')

  btn?.addEventListener('click', () => {
    btn.classList.toggle('open')
    menu?.classList.toggle('hidden')
  })

  // Cerrar al hacer click en un link
  links.forEach(link => {
    link.addEventListener('click', () => {
      btn?.classList.remove('open')
      menu?.classList.add('hidden')
    })
  })

  // Marcar sección activa
  const sections = document.querySelectorAll('section[id]')
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        links.forEach((link) => {
          link.classList.remove('active')
          if (link.getAttribute('href') === `#${entry.target.id}`) {
            link.classList.add('active')
          }
        })
      }
    })
  }, { rootMargin: '-30% 0px -60% 0px' })

  sections.forEach((section) => observer.observe(section))
</script>
