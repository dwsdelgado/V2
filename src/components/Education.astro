---
import { Image } from 'astro:assets'
import education from '@/data/education.json'
import Skills from './ui/Skills.astro'
import { getImageFromAssets } from '@/utils'

const { condensed = false } = Astro.props

const items = condensed ? education.slice(0, 3) : education
---

<section
  class:list={['pb-20 scroll-m-32', Astro.props.class]}
  id="education"
>
  <div class="space-y-12">
    <div class="text-center space-y-4">
      <h2 class="section-title">Certificaciones</h2>
      <p class="text-stone-600 dark:text-stone-400 text-lg max-w-3xl mx-auto">
        Certificaciones profesionales
      </p>
    </div>

    <div class="space-y-6">
      {
        items.map((education) => (
          <div class="card p-8 group hover:shadow-lg">
            <div class="flex items-start gap-6">
              {education.logoUrl && (
                <div class="shrink-0">
                  <Image
                    src={getImageFromAssets(education.logoUrl)}
                    alt={`Logo - ${education.school}`}
                    class="rounded-xl shadow-xs"
                    width={56}
                    height={56}
                    loading="lazy"
                  />
                </div>
              )}
              
              <div class="flex-1 space-y-4">
                <div class="space-y-2">
                  <h3 class="text-xl font-medium text-stone-900 dark:text-stone-100" set:html={education.degree} />
                  
                  <div class="flex items-center gap-3 text-stone-600 dark:text-stone-400 text-sm flex-wrap">
                    <p class="font-medium" set:html={education.school} />
                    <div class="w-1 h-1 bg-stone-400 rounded-full"></div>
                    <p set:html={education.location} />
                    <div class="w-1 h-1 bg-stone-400 rounded-full"></div>
                    <p set:html={education.date} />
                  </div>
                </div>
                
                <p
                  class="text-stone-600 dark:text-stone-400 leading-relaxed"
                  set:html={education.description}
                />
                
                <Skills list={education.skills || []} />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
