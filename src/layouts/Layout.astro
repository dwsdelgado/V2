---
import '@fontsource-variable/inter'
import '@/styles/global.css'
import Navbar from '@/components/ui/Navbar.astro'
import Footer from '@/components/ui/Footer.astro'
import Printable from '@/components/Printable.astro'
import ParticlesBackground from '@/components/ui/ParticlesBackground.astro'
import me from '@/data/me.json'
import { HTMLtoText } from '@/utils'

const { title } = Astro.props
---

<!doctype html>
<html lang='es' class='scroll-smooth antialiased'>
	<head>
		<meta charset='UTF-8' />
		<meta name='description' content={HTMLtoText(me.description)} />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<link rel='icon' type='image/png' href='/favicon.png' />
		<link rel='sitemap' href='/sitemap-index.xml' />
		<meta name='generator' content={Astro.generator} />
		<title>{title}</title>
		<meta name='robots' content='index, follow' />

		<!-- Open Graph / Social Media -->
		<meta property='og:type' content='website' />
		<meta property='og:title' content={title} />
		<meta property='og:description' content={HTMLtoText(me.description)} />
		<meta property='og:image' content='/favicon.png' />
		<meta property='og:locale' content='es_CO' />

		<!-- Twitter -->
		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content={title} />
		<meta name='twitter:description' content={HTMLtoText(me.description)} />

		<!-- Additional SEO -->
		<meta name='author' content={me.fullName} />
		<meta name='keywords' content='DevOps, Infrastructure Engineer, Linux, Red Hat, Ansible, Docker, Kubernetes, AWS, Cloud' />

		<!-- Iconify for brand logos -->
		<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>

		<script is:inline>
			const isDarkTheme =
				'theme' in localStorage
					? localStorage.theme === 'dark'
					: window.matchMedia('(prefers-color-scheme: dark)').matches

			document.documentElement.dataset.theme = isDarkTheme ? 'dark' : 'light'
		</script>

		<script>
			function animate() {
				const animatedElements = document.querySelectorAll('.animate')

				animatedElements.forEach((element, index) => {
					setTimeout(() => {
						element.classList.add('show')
					}, index * 200)
				})
			}

			// Prevent FOUC by showing content when ready
			document.addEventListener('DOMContentLoaded', () => {
				document.body.classList.add('!visible')
				animate()
			})
		</script>
	</head>
	<body class="invisible">
		<ParticlesBackground />
		<div class='no-print '>
			<Navbar />
			<main class='max-w-6xl mx-auto px-6 lg:px-8 py-8'>
				<slot />
			</main>
			<Footer />
		</div>
		<div class='print'>
			<Printable />
		</div>
	</body>
</html>
